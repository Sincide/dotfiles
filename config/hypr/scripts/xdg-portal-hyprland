#!/bin/bash

# Kill existing portal instances
killall xdg-desktop-portal-hyprland
killall xdg-desktop-portal-wlr
killall xdg-desktop-portal-gnome
killall xdg-desktop-portal

# Wait for processes to shutdown
sleep 1

# Start portals in correct order
/usr/lib/xdg-desktop-portal-hyprland &
sleep 2
/usr/lib/xdg-desktop-portal &

# NOTE: Theming (GTK, icons, waybar) is handled by the dynamic theming system
# in ~/dotfiles/scripts/restore-wallpaper.sh and wallpaper-theme-changer-optimized.sh
# This prevents conflicts with Material You dynamic theming 