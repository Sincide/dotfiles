{
    "layer": "bottom",
    "position": "bottom",
    "height": 38,
    "spacing": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 5,
    "margin-right": 5,
    "exclusive": true,
    "gtk-layer-shell": true,
    "passthrough": false,
    "hide_on_fullscreen": false,
    
    "modules-left": [
        "custom/ai-dashboard"
    ],
    
    "modules-center": [
        "custom/gpu-info"
    ],
    
    "modules-right": [
        "clock"
    ],
    
    "custom/gpu-info": {
        "format": "{text}",
        "exec": "~/.config/waybar/scripts/gpu-info.sh",
        "return-type": "json",
        "interval": 2,
        "tooltip": true,
        "on-click": "kitty --class floating -e btop"
    },

    "custom/ai-dashboard": {
        "format": "{text}",
        "exec": "~/.config/waybar/scripts/ai-dashboard.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true,
        "on-click": "kitty --class floating -e bash -c 'cd ~/dotfiles && scripts/ai/dashboard'"
    },

    "clock": {
        "format": " {:%H:%M %Y-%m-%d W%V}",
        "format-alt": " {:%A, %B %d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "tooltip": true,
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    }
} 