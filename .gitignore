# Ignore backup files
*.bak
*~

# Ignore logs
*.log

# Ignore compiled Python files
*.pyc
__pycache__/

# Ignore fish generated files
config/fish/fish_variables
config/fish/fishd.*
config/fish/conf.d/*

# Ignore local history
.*history
.directory

# Ignore cache directories
.cache/
cache/

# Ignore Waybar toggle files that change frequently
config/waybar/config
config/waybar/style.css

# Allow encrypted private files
!private/
!private/*.gpg 