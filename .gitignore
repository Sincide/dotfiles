# Ignore backup files
*.bak
*~

# Ignore logs
*.log

# Ignore compiled Python files
*.pyc
__pycache__/

# Ignore fish generated files
config/fish/fish_variables
config/fish/fishd.*
config/fish/conf.d/*

# Ignore local history
.*history
.directory

# Ignore cache directories
.cache/
cache/

# Allow encrypted private files
!private/
!private/*.gpg

# ================================
# AI THEMING SYSTEM FILES
# ================================

# AI processing temporary files
/tmp/ai-*.log
/tmp/ai-*.json
/tmp/ai-pipeline*
/tmp/matugen*.log
/tmp/wallpaper-*.log
/tmp/color-*.log
/tmp/material-you-*.log
/tmp/harmony-*.log
/tmp/accessibility-*.log

# AI color processing output files
/tmp/ai-optimized-colors.json
/tmp/ai-enhanced-result.json
/tmp/ai-updated-colors.json
/tmp/ai-baseline.log
/tmp/color-harmony-*.json
/tmp/accessibility-*.json
/tmp/vision-*.json
/tmp/enhanced-*.json
/tmp/harmony-*.json
/tmp/math-*.json
/tmp/vision-analysis-enhanced.json
/tmp/harmony-analysis-enhanced.json
/tmp/accessibility-analysis-enhanced.json
/tmp/test-matugen-colors.json
/tmp/matugen_colors.json
/tmp/vision-theme-recommendations.json
/tmp/optimized-colors.json

# AI configuration (preserve user config)
!config/dynamic-theming/ai-config.conf

# AI development and testing files
ai-development/temp/
ai-development/test-output/
experiments/temp/
experiments/*/test-icons/
experiments/*/output/

# ================================
# DYNAMIC THEMING GENERATED FILES
# ================================

# Generated theme files (dynamically created by matugen)
config/gtk-3.0/colors.css
config/gtk-4.0/colors.css
config/qt5ct/colors/matugen.conf
config/qt6ct/colors/matugen.conf
config/waybar/style-dynamic.css
config/waybar/style-bottom-dynamic.css
config/dunst/dunstrc-dynamic
config/kitty/current-theme.conf
config/kitty/theme-dynamic.conf
config/fuzzel/config-dynamic
config/fuzzel/fuzzel.ini
config/hypr/conf/colors.conf

# Keep templates but ignore generated content in backups
backups/*/config/
backups/*/scripts/
backups/*/experiments/

# Dynamic wallpaper state
config/dynamic-theming/last-wallpaper
config/dynamic-theming/wallpaper-cache/

# Generated icon themes
.local/share/icons/MaterialYou-*/
experiments/material-you-icons/icon-themes/MaterialYou-*/
experiments/material-you-icons/icon-themes/MaterialYou-*/**/*.svg

# Material You icon generation temporary files
experiments/material-you-icons/temp-icons/
experiments/material-you-icons/scripts/temp-*
experiments/material-you-icons/*.svg
experiments/material-you-icons/*.png
experiments/material-you-icons/test-output/

# Icon and theme cache files
~/.cache/icon-theme.cache
~/.cache/gtk-*
~/.cache/qt*
.cache/fontconfig/
.cache/mesa_shader_cache/
.cache/thumbnails/

# ================================
# SYSTEM BACKUPS & LARGE FILES
# ================================

# Large backup directories (keep structure, ignore content)
backups/*/scripts/
backups/*/config/
backups/*/experiments/
# Keep backup directory structure and small files
!backups/*/
!backups/*/*.txt
!backups/*/*.md

# ================================
# SYSTEM-SPECIFIC FILES
# ================================

# User-specific monitor configurations
config/hypr/conf/monitors-current.conf

# Performance benchmark files
performance-*.log
benchmark-*.json

# System state files
.swww/
.wallpaper-cache/

# Hyprland generated files
config/hypr/.hyprland.lock
config/hypr/hyprland.log

# swww daemon files
.config/swww/
swww.log

# Wallpaper and transition state
config/dynamic-theming/transition-*.log
config/dynamic-theming/performance-*.log
config/dynamic-theming/cache/



# ================================
# DEVELOPMENT & TESTING
# ================================

# Test outputs and temporary scripts
test-*.sh
temp-*.sh
debug-*.sh

# Script execution logs and timing
scripts/*/timing-*.log
scripts/*/performance-*.log
scripts/*/debug-*.log

# AI script development files
scripts/ai/temp-*
scripts/ai/test-*
scripts/ai/backup-*

# Go build outputs
scripts/ai/dashboard
scripts/ai/go.sum

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS-specific files
.DS_Store
Thumbs.db

# ================================
# PACKAGE MANAGER FILES  
# ================================

# Node.js (if any scripts use it)
node_modules/
package-lock.json

# Python virtual environments (if any)
venv/
env/
.venv/ 