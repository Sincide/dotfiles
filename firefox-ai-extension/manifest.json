{
  "applications": {
    "gecko": {
      "id": "ai-dynamic-colors@martin.dotfiles"
    }
  },
  "manifest_version": 2,
  "name": "AI Dynamic Colors",
  "version": "1.0.0",
  "description": "Real-time AI-optimized color themes from your wallpaper",
  
  "permissions": [
    "storage",
    "activeTab",
    "http://*/*",
    "https://*/*"
  ],
  
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "all_frames": true
  }],
  
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "AI Dynamic Colors"
  },
  
  "options_page": "options.html"
}