# Enable syntax highlighting
include "/usr/share/nano/*.nanorc"
include "/usr/share/nano/extra/*.nanorc"

# Interface options
set titlecolor brightwhite,blue
set statuscolor brightwhite,blue
set errorcolor brightwhite,red
set selectedcolor brightwhite,magenta
set stripecolor yellow
set numbercolor cyan
set keycolor cyan
set functioncolor green

# Enable line numbers
set linenumbers

# Enable mouse support
set mouse

# Make the 'Delete' key work as expected
#set rebinddelete

# Tab size
set tabsize 4
set tabstospaces

# Enable auto-indentation
set autoindent

# Backup files
set backup
set backupdir "~/.cache/nano/backups"

# Scrolling
#set smooth
set constantshow

# Don't wrap text at all
#set nowrap

# Enable soft line wrapping for easier viewing
set softwrap

# Enable experimental stuff
set multibuffer

# Don't convert files from DOS/Mac format
set noconvert

# Use this tab size instead of the default; it must be greater than 0
set tabsize 4

# Enable undo/redo
#set undo

# Improved file browser settings
set showcursor
set smarthome
set historylog
set positionlog
set quickblank 